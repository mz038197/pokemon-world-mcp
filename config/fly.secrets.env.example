# Copy to $HOME/.pokemon-world-mcp/fly.secrets.env (UTF-8 without BOM)
# Windows: %USERPROFILE%\.pokemon-world-mcp\fly.secrets.env
# Then: powershell -ExecutionPolicy Bypass -File scripts\deploy-fly.ps1
#
# Local SQLite (when DATABASE_URL unset): *.db under $HOME/.pokemon-world-mcp/ — never inside the repo.
# Production: set Neon DATABASE_URL below; do not rely on SQLite on Fly.

# Neon / Postgres — same connection string as vans-mcp / vans-coding-router (api_keys + pokemon_saves).
DATABASE_URL=

# PUBLIC_URL lives in fly.toml [env] — do not set it as a Fly secret.

# Local/dev only — never set this in production Fly secrets.
# MCP_DEV_BYPASS_KEY=vcr_sk_dev_local_only
