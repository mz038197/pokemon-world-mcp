# Copy to $HOME/.pokemon-world-mcp/fly.secrets.env (UTF-8 without BOM)
# Windows: %USERPROFILE%\.pokemon-world-mcp\fly.secrets.env
# Then: powershell -ExecutionPolicy Bypass -File scripts\deploy-fly.ps1
#
# Local SQLite (when POKEMON_DATABASE_URL unset): *.db under $HOME/.pokemon-world-mcp/ — never inside the repo.
# Production: set both Neon URLs below; do not rely on SQLite on Fly.

# Router Neon — same as vans-mcp / vans-coding-router (api_keys only).
DATABASE_URL=

# Game Neon — pokemon_saves + pokemon_catalog_cache (separate from router).
POKEMON_DATABASE_URL=

# PUBLIC_URL lives in fly.toml [env] — do not set it as a Fly secret.

# Local/dev only — never set this in production Fly secrets.
# MCP_DEV_BYPASS_KEY=vcr_sk_dev_local_only

# Optional: catalog cache TTL hours (default 24).
# CATALOG_CACHE_TTL_HOURS=24
